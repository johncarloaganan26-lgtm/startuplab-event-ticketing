# Server
BACKEND_PORT=5000
NODE_ENV=production

# CORS - Add your production domain here
ALLOWED_ORIGINS=https://your-domain.vercel.app,http://localhost:3000

# Supabase - Get these from your Supabase dashboard
SUPABASE_URL=https://your-supabase-project.supabase.co/
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Frontend/Backend URLs - Update for production
FRONTEND_URL=https://your-frontend.vercel.app
SERVER_BASE_URL=https://your-backend.vercel.app

# HitPay - Get these from your HitPay dashboard
HITPAY_BASE_URL=https://api.hit-pay.com
HITPAY_API_KEY=your-hitpay-api-key
HITPAY_SALT=your-hitpay-salt
HITPAY_ENABLED=true

# Security - Key for encrypting gateway credentials in the database
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-key-here-generate-with-node-command
